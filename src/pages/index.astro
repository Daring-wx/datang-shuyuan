---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="首页">
  <main class="home">
    <h1 class="home__title">个人博客</h1>
    <p class="home__subtitle">建设中...</p>
  </main>
</BaseLayout>

<style>
  .home {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .home__title {
    font-size: 42px;
    font-weight: 300;
    letter-spacing: 4px;
    color: #2c2c2c;
    margin-bottom: 16px;
  }
  .home__subtitle {
    font-size: 13px;
    color: #888;
    letter-spacing: 2px;
  }
</style>
